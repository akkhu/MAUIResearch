<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pdf="clr-namespace:Syncfusion.Maui.PdfViewer;assembly=Syncfusion.Maui.PdfViewer"
             xmlns:vm="clr-namespace:AnnotationApp.ViewModels"
             x:Class="AnnotationApp.MainPage">
    <ContentPage.BindingContext>
        <vm:MainPageViewModel />
    </ContentPage.BindingContext>

    <pdf:SfPdfViewer x:Name="pdfViewer"
                    DocumentSource="{Binding DocumentPath}"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand" />
</ContentPage>
